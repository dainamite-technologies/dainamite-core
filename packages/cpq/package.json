{
  "name": "@dainamite/cpq",
  "version": "0.2.1",
  "description": "Dainamite CPQ — Configure, Price, Quote engine for Open Mercato (configurable products, multi-charge pricing tables, guided quoting, customer inventory, orders).",
  "type": "module",
  "main": "./dist/modules/cpq/index.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "watch": "node watch.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "chokidar": "^4.0.3"
  },
  "exports": {
    ".": {
      "types": "./src/modules/cpq/index.ts",
      "default": "./dist/modules/cpq/index.js"
    },
    "./modules/cpq": {
      "types": "./src/modules/cpq/index.ts",
      "default": "./dist/modules/cpq/index.js"
    },
    "./*.ts": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./*.tsx": {
      "types": "./src/*.tsx",
      "default": "./dist/*.js"
    },
    "./*.json": "./src/*.json",
    "./*": {
      "types": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    },
    "./*/*.json": "./src/*/*.json",
    "./*/*": {
      "types": [
        "./src/*/*.ts",
        "./src/*/*.tsx"
      ],
      "default": "./dist/*/*.js"
    },
    "./*/*/*.json": "./src/*/*/*.json",
    "./*/*/*": {
      "types": [
        "./src/*/*/*.ts",
        "./src/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*/*.json": "./src/*/*/*/*.json",
    "./*/*/*/*": {
      "types": [
        "./src/*/*/*/*.ts",
        "./src/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*.js"
    },
    "./*/*/*/*/*.json": "./src/*/*/*/*/*.json",
    "./*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*.ts",
        "./src/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*.json": "./src/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*/*.json": "./src/*/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*/*/*.json": "./src/*/*/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*/*/*/*.json": "./src/*/*/*/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*/*/*/*.js"
    },
    "./*/*/*/*/*/*/*/*/*/*.json": "./src/*/*/*/*/*/*/*/*/*/*.json",
    "./*/*/*/*/*/*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*/*/*/*/*/*.ts",
        "./src/*/*/*/*/*/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*/*/*/*/*/*.js"
    }
  },
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.0",
    "@mikro-orm/decorators": "^7.0.0",
    "@mikro-orm/postgresql": "^7.0.0",
    "@open-mercato/core": "^0.6.0",
    "@open-mercato/events": "^0.6.0",
    "@open-mercato/shared": "^0.6.0",
    "@open-mercato/ui": "^0.6.0",
    "@tanstack/react-table": "^8.0.0 || ^9.0.0",
    "awilix": "^12.0.0",
    "bcryptjs": "^3.0.0",
    "lucide-react": "^0.400.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.0",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
